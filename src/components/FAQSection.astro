---
export interface FAQ { q: string; a: string; }
export interface Props {
  kicker?: string;
  heading?: string;
  accent?: string;
  intro?: string;
  faqs: FAQ[];
  background?: 'offwhite' | 'cream' | 'white';
}
const {
  kicker = 'Frequently asked',
  heading = 'Questions we hear a lot',
  accent,
  intro,
  faqs,
  background = 'offwhite',
} = Astro.props;

const bgMap = { offwhite: '#FAFAF7', cream: '#F6F5F0', white: '#FFFFFF' } as const;
const bg = bgMap[background];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};
---

<section class="faq-section" style={`background:${bg};padding:100px 24px;`}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="faq-inner">
    <div class="reveal faq-head">
      <span class="label">{kicker}</span>
      <h2 class="faq-heading">
        {heading}{accent && <span class="faq-accent"> {accent}</span>}{!accent && '.'}
      </h2>
      {intro && <p class="faq-intro">{intro}</p>}
    </div>

    <div class="reveal faq-list">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary class="faq-q">
            <span>{f.q}</span>
            <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </summary>
          <div class="faq-a">
            <p>{f.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-inner { max-width: 880px; margin: 0 auto; }
  .faq-head { text-align: center; margin-bottom: 48px; }
  .faq-heading {
    font-size: clamp(28px, 4.5vw, 52px);
    color: #0A0A0B;
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }
  .faq-accent { color: #14746F; }
  .faq-intro {
    margin: 18px auto 0;
    max-width: 620px;
    font-size: 16px;
    color: #4A4A4E;
    line-height: 1.6;
    letter-spacing: -0.005em;
  }

  .faq-list {
    border-top: 1px solid #EAEAEC;
  }
  .faq-item {
    border-bottom: 1px solid #EAEAEC;
  }
  .faq-q {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    padding: 22px 4px;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 17px;
    color: #0A0A0B;
    letter-spacing: -0.015em;
    line-height: 1.4;
    transition: color 0.15s;
  }
  .faq-q:hover { color: #14746F; }
  .faq-q > span:first-child { flex: 1; }

  .faq-chevron {
    flex-shrink: 0;
    color: #14746F;
    margin-top: 3px;
    transition: transform 0.2s;
  }
  details[open] > .faq-q .faq-chevron { transform: rotate(180deg); }

  .faq-a {
    padding: 0 4px 24px;
    max-width: 760px;
  }
  .faq-a p {
    margin: 0;
    font-size: 15.5px;
    color: #4A4A4E;
    line-height: 1.72;
    letter-spacing: -0.005em;
  }

  @media (max-width: 640px) {
    .faq-section { padding: 72px 18px !important; }
    .faq-head { margin-bottom: 36px; }
    .faq-q { padding: 18px 2px; font-size: 15.5px; gap: 14px; line-height: 1.45; }
    .faq-chevron { width: 16px; height: 16px; }
    .faq-a { padding: 0 2px 20px; }
    .faq-a p { font-size: 15px; line-height: 1.7; }
  }
</style>
