---
const navLinks = [
  {
    label: 'Services', href: '/services',
    dropdown: [
      { label: 'AI Sales Automation',            href: '/services/ai-sales-automation' },
      { label: 'Show Up on ChatGPT',             href: '/services/show-up-on-chatgpt' },
      { label: 'Qualified Leads',                href: '/services/qualified-leads' },
      { label: 'A Website That Sells',           href: '/services/website-that-sells' },
      { label: 'AI Business Process Automation', href: '/services/ai-business-process-automation' },
    ],
  },
  {
    label: 'Industries', href: '#',
    dropdown: [
      { label: 'Home Services',               href: '/industries/home-services' },
      { label: 'Hospitality',                 href: '/industries/hospitality' },
      { label: 'Commercial & Facility',       href: '/industries/commercial-facility' },
      { label: 'Financial Services',          href: '/industries/financial-services' },
      { label: 'Manufacturing & Industrial',  href: '/industries/manufacturing-industrial' },
    ],
  },
  { label: 'Contact', href: '/contact' },
];
---

<header id="site-nav" style="position:fixed;top:0;left:0;right:0;z-index:60;transition:all 0.3s; background:rgba(255,255,255,0.75); backdrop-filter:saturate(180%) blur(20px); -webkit-backdrop-filter:saturate(180%) blur(20px); border-bottom:1px solid rgba(234,234,236,0.6);">
  <div style="max-width:1240px;margin:0 auto;padding:14px 32px;display:flex;align-items:center;justify-content:space-between;gap:12px;" class="nav-inner">

    <!-- Logo + market tag -->
    <a href="/" class="nav-logo" style="flex-shrink:0;display:flex;flex-direction:column;gap:2px;text-decoration:none;line-height:1;min-width:0;">
      <img src="/logo.png" alt="Click2Revenue" class="nav-logo-img" style="height:26px;width:auto;"/>
      <span class="nav-market-tag" style="font-family:'Inter',sans-serif;font-size:9.5px;font-weight:500;letter-spacing:1.5px;color:#8A8A90;margin-top:4px;text-transform:uppercase;">Australia · United States</span>
    </a>

    <!-- Desktop nav -->
    <nav id="desktop-nav" style="display:flex;align-items:center;gap:32px;">
      {navLinks.map(link => (
        <div style="position:relative;" class="nav-item">
          <a href={link.href}
             style="font-family:'Inter',sans-serif;font-weight:500;font-size:14px;color:#0A0A0B;text-decoration:none;display:flex;align-items:center;gap:4px;padding:24px 0;transition:color 0.2s;letter-spacing:-0.005em;"
             onmouseover="this.style.color='#14746F';"
             onmouseout="this.style.color='#0A0A0B';">
            {link.label}
            {link.dropdown && (
              <svg style="width:11px;height:11px;opacity:0.5;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
              </svg>
            )}
          </a>
          {link.dropdown && (
            <div class="dropdown" style="position:absolute;top:100%;left:50%;transform:translateX(-50%);min-width:280px;background:rgba(255,255,255,0.95);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-radius:14px;box-shadow:0 12px 48px rgba(10,10,11,0.12);border:1px solid rgba(234,234,236,0.8);padding:8px;opacity:0;visibility:hidden;transition:all 0.2s;pointer-events:none;">
              {link.dropdown.map(item => (
                <a href={item.href}
                   style="display:block;padding:11px 16px;font-size:13.5px;color:#0A0A0B;text-decoration:none;font-family:'Inter',sans-serif;font-weight:500;border-radius:8px;transition:all 0.15s;letter-spacing:-0.005em;"
                   onmouseover="this.style.background='#FAFAF7';this.style.color='#14746F';"
                   onmouseout="this.style.background='';this.style.color='#0A0A0B';">
                  {item.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </nav>

    <!-- Desktop CTA -->
    <a href="/contact" id="desktop-cta" style="font-family:'Inter',sans-serif;font-weight:600;font-size:13.5px;background:#0A0A0B;color:white;padding:10px 20px;border-radius:8px;text-decoration:none;transition:all 0.2s;white-space:nowrap;letter-spacing:-0.005em;"
       onmouseover="this.style.background='#14746F';"
       onmouseout="this.style.background='#0A0A0B';">
      Free audit →
    </a>

    <!-- Mobile hamburger -->
    <button id="hamburger" aria-label="Menu" aria-expanded="false" aria-controls="mobile-drawer"
            style="display:none;flex-direction:column;align-items:center;justify-content:center;gap:5px;width:44px;height:44px;padding:0;background:none;border:none;cursor:pointer;margin-right:-10px;position:relative;z-index:2;">
      <span class="bar" style="display:block;width:22px;height:2px;background:#0A0A0B;border-radius:2px;transition:all 0.25s;"></span>
      <span class="bar" style="display:block;width:22px;height:2px;background:#0A0A0B;border-radius:2px;transition:all 0.25s;"></span>
      <span class="bar" style="display:block;width:22px;height:2px;background:#0A0A0B;border-radius:2px;transition:all 0.25s;"></span>
    </button>
  </div>
</header>

<!-- Backdrop (must be OUTSIDE the header so the header's backdrop-filter does not
     become the containing block for this fixed-positioned element in WebKit).   -->
<div id="mobile-backdrop" aria-hidden="true"></div>

<!-- Mobile drawer — side sheet, ~88vw capped at 380px -->
<aside id="mobile-drawer" aria-hidden="true" aria-label="Mobile menu">
  <div class="drawer-inner">
    <nav class="drawer-nav">
      {navLinks.map(link => (
        <div class="drawer-group">
          <a href={link.href} class="drawer-link">{link.label}</a>
          {link.dropdown && (
            <div class="drawer-sublinks">
              {link.dropdown.map(item => (
                <a href={item.href} class="drawer-sublink">{item.label}</a>
              ))}
            </div>
          )}
        </div>
      ))}
    </nav>
    <a href="/contact" class="btn-primary drawer-cta">Get my free audit →</a>
  </div>
</aside>

<style>
  .nav-item:hover .dropdown {
    opacity: 1 !important;
    visibility: visible !important;
    pointer-events: auto !important;
  }

  /* ─── Mobile drawer as a right-side sheet ─── */
  #mobile-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(10, 10, 11, 0.45);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    z-index: 55;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }
  #mobile-backdrop.open {
    opacity: 1;
    pointer-events: auto;
  }

  #mobile-drawer {
    position: fixed;
    top: 0;
    right: 0;
    height: 100vh;
    height: 100dvh;                 /* iOS Safari URL-bar aware */
    width: min(88vw, 380px);
    background: white;
    z-index: 58;                    /* below header (60), above backdrop (55) */
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: -20px 0 60px rgba(10, 10, 11, 0.12);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
    display: none;                  /* hidden entirely on desktop */
  }
  #mobile-drawer.open {
    transform: translateX(0);
  }

  .drawer-inner {
    padding: 84px 24px 40px;        /* top padding clears the fixed nav */
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }
  .drawer-nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .drawer-group + .drawer-group {
    margin-top: 4px;
  }
  .drawer-link {
    display: block;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 19px;
    color: #0A0A0B;
    text-decoration: none;
    padding: 12px 0;
    border-bottom: 1px solid #EAEAEC;
    letter-spacing: -0.02em;
  }
  .drawer-sublinks {
    padding: 6px 0 6px 4px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .drawer-sublink {
    display: block;
    padding: 8px 0;
    font-size: 14px;
    color: #4A4A4E;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    letter-spacing: -0.005em;
  }
  .drawer-cta {
    margin-top: auto;
    justify-content: center;
    padding-top: 24px;
  }

  /* Enable the drawer + shrink logo strip on narrow screens */
  @media (max-width: 900px) {
    #desktop-nav { display: none !important; }
    #desktop-cta { display: none !important; }
    #hamburger { display: flex !important; }
    #mobile-drawer { display: block; }
    .nav-inner { padding: 10px 18px !important; }
    .nav-logo-img { height: 24px !important; }
    .nav-market-tag { font-size: 9px !important; letter-spacing: 1.2px !important; margin-top: 3px !important; }
  }
  @media (max-width: 420px) {
    .nav-inner { padding: 8px 14px !important; }
    .nav-logo-img { height: 22px !important; }
    .nav-market-tag { display: none !important; }
    .drawer-inner { padding: 78px 22px 36px; }
    .drawer-link { font-size: 18px; padding: 11px 0; }
  }

  /* Body scroll-lock helper (class, not inline, so nothing leaks if JS crashes) */
  :global(body.no-scroll) { overflow: hidden; }
</style>

<script>
  const nav     = document.getElementById('site-nav')!;
  const burger  = document.getElementById('hamburger')!;
  const drawer  = document.getElementById('mobile-drawer')!;
  const backdrop = document.getElementById('mobile-backdrop')!;
  const bars    = document.querySelectorAll<HTMLElement>('.bar');
  let open = false;

  function setOpen(v: boolean) {
    open = v;
    drawer.classList.toggle('open', v);
    backdrop.classList.toggle('open', v);
    bars[0].style.transform = v ? 'rotate(45deg) translate(5px,5px)' : '';
    bars[1].style.opacity   = v ? '0' : '1';
    bars[2].style.transform = v ? 'rotate(-45deg) translate(5px,-5px)' : '';
    burger.setAttribute('aria-expanded', String(v));
    drawer.setAttribute('aria-hidden', String(!v));
    backdrop.setAttribute('aria-hidden', String(!v));
    document.body.classList.toggle('no-scroll', v);
  }

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav.style.background = 'rgba(255,255,255,0.88)';
      nav.style.boxShadow  = '0 1px 3px rgba(10,10,11,0.04)';
    } else {
      nav.style.background = 'rgba(255,255,255,0.75)';
      nav.style.boxShadow  = 'none';
    }
  }, { passive: true });

  burger.addEventListener('click', () => setOpen(!open));
  backdrop.addEventListener('click', () => setOpen(false));

  // Close drawer when any link inside it is tapped
  drawer.querySelectorAll<HTMLAnchorElement>('a').forEach((a) => {
    a.addEventListener('click', () => setOpen(false));
  });

  // ESC to close
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && open) setOpen(false);
  });

  // If resized to desktop while drawer open, close it
  window.addEventListener('resize', () => {
    if (window.innerWidth > 900 && open) setOpen(false);
  });
</script>
