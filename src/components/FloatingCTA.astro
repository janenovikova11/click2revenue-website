<!-- Geo-aware floating SMS/Call button — AU visitors get AU number, everyone else gets US -->
<div id="floating-cta" class="fixed bottom-6 right-6 z-50 opacity-0 translate-y-4 transition-all duration-300 pointer-events-none">
  <a
    id="floating-link"
    href="tel:+19252909985"
    class="flex items-center gap-3 bg-brand-dark text-white font-display font-semibold text-[15px] px-6 py-4 rounded-full shadow-lg hover:bg-brand-mid transition-all duration-200 hover:scale-105"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round"
        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 8V5z"/>
    </svg>
    <span id="floating-label">Call Us</span>
  </a>
</div>

<script>
  const btn = document.getElementById('floating-cta') as HTMLElement;
  const link = document.getElementById('floating-link') as HTMLAnchorElement;
  const label = document.getElementById('floating-label') as HTMLElement;

  // Geo-aware number
  const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
  if (tz && (tz.includes('Australia') || tz.includes('Pacific/Auckland'))) {
    link.href = 'tel:+61424985687';
    label.textContent = 'Call AU';
  }

  // Show after 60% scroll
  window.addEventListener('scroll', () => {
    const scrolled = window.scrollY / (document.body.scrollHeight - window.innerHeight);
    if (scrolled > 0.6) {
      btn.style.opacity = '1';
      btn.style.transform = 'translateY(0)';
      btn.style.pointerEvents = 'auto';
    }
  });
</script>
