---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
import Icon from '../components/Icon.astro';
---

<BaseLayout
  title="Contact Click2Revenue — Free Strategy Call | Click2Revenue"
  description="Book a free 30-minute strategy call with Click2Revenue. AI responds instantly, humans follow up during business hours. AU and US numbers available."
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Contact Click2Revenue",
    "url": "https://click2revenue.com/contact",
    "mainEntity": {
      "@type": "Organization",
      "name": "Click2Revenue",
      "telephone": ["+61-424-985-687", "+1-925-290-9985"],
      "email": "jane@click2revenue.com",
      "contactPoint": [
        { "@type": "ContactPoint", "telephone": "+61-424-985-687", "contactType": "customer service", "areaServed": "AU", "availableLanguage": ["en"] },
        { "@type": "ContactPoint", "telephone": "+1-925-290-9985", "contactType": "customer service", "areaServed": "US", "availableLanguage": ["en"] }
      ]
    }
  })} />

  <!-- HERO -->
  <section style="background:#FAFAF7;padding:140px 24px 80px;position:relative;overflow:hidden;">
    <div aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;overflow:hidden;">
      <div style="position:absolute;top:-180px;right:-120px;width:900px;height:900px;background:radial-gradient(circle,rgba(153,226,180,0.22) 0%,transparent 60%);border-radius:50%;filter:blur(20px);"></div>
      <div style="position:absolute;bottom:-200px;left:-150px;width:600px;height:600px;background:radial-gradient(circle,rgba(20,116,111,0.08) 0%,transparent 55%);border-radius:50%;filter:blur(20px);"></div>
    </div>

    <div style="position:relative;max-width:900px;margin:0 auto;text-align:center;">
      <span class="label">Contact</span>
      <h1 style="font-size:clamp(48px,7vw,88px);font-weight:800;color:#0A0A0B;margin:0 0 24px;line-height:0.98;letter-spacing:-0.045em;">
        Let's <span style="color:#14746F;">talk.</span>
      </h1>
      <p style="font-size:clamp(17px,1.6vw,20px);color:#4A4A4E;line-height:1.55;margin:0 auto;max-width:620px;font-weight:400;letter-spacing:-0.01em;">
        Drop your details. Our AI is on 24/7 and will be with you straight away. A human takes over as soon as business hours kick in. Between Queensland and Delaware, that's most of the day.
      </p>
    </div>
  </section>

  <!-- FORM -->
  <div id="full-form-anchor"></div>
  <LeadForm
    headline="Start with a free audit."
    subheadline="Our AI replies instantly. A human follows up during business hours."
    service="general_enquiry"
    source="contact_page"
  />

  <!-- OFFICES -->
  <section style="background:white;padding:100px 24px;border-top:1px solid #EAEAEC;">
    <div style="max-width:1100px;margin:0 auto;">
      <div class="reveal" style="text-align:center;margin-bottom:56px;">
        <span class="label">Find us</span>
        <h2 style="font-size:clamp(32px,4.5vw,48px);color:#0A0A0B;margin:0;line-height:1.05;letter-spacing:-0.03em;">
          Two offices. <span style="color:#14746F;">One team.</span>
        </h2>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;" class="offices-grid">

        <!-- USA -->
        <div class="reveal" style="padding:40px;background:#FAFAF7;border:1px solid #EAEAEC;border-radius:18px;">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
            <span style="font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:#14746F;font-weight:700;">USA Office</span>
          </div>
          <h3 style="font-size:24px;color:#0A0A0B;margin:0 0 20px;letter-spacing:-0.02em;">Lewes, Delaware</h3>
          <address style="font-style:normal;color:#4A4A4E;font-size:15px;line-height:1.7;margin:0 0 24px;">
            16192 Coastal Highway<br/>
            Lewes, Delaware 19958<br/>
            United States
          </address>
          <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:24px;">
            <a href="tel:+19252909985" style="display:inline-flex;align-items:center;gap:10px;color:#0A0A0B;text-decoration:none;font-weight:600;font-size:15px;transition:color 0.2s;" onmouseover="this.style.color='#14746F';" onmouseout="this.style.color='#0A0A0B';">
              <Icon name="phone" size={16} stroke="#14746F" /> +1 925 290 9985
            </a>
            <a href="mailto:jane@click2revenue.com" style="display:inline-flex;align-items:center;gap:10px;color:#4A4A4E;text-decoration:none;font-size:14px;font-weight:500;transition:color 0.2s;" onmouseover="this.style.color='#14746F';" onmouseout="this.style.color='#4A4A4E';">
              jane@click2revenue.com
            </a>
          </div>
          <p style="font-size:13px;color:#8A8A90;margin:0;padding-top:20px;border-top:1px solid #EAEAEC;">
            Business hours: Mon–Fri 9am–5pm EST
          </p>
        </div>

        <!-- Australia -->
        <div class="reveal" style="padding:40px;background:#FAFAF7;border:1px solid #EAEAEC;border-radius:18px;">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
            <span style="font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:#14746F;font-weight:700;">Australia Office</span>
          </div>
          <h3 style="font-size:24px;color:#0A0A0B;margin:0 0 20px;letter-spacing:-0.02em;">Sunshine Coast, QLD</h3>
          <address style="font-style:normal;color:#4A4A4E;font-size:15px;line-height:1.7;margin:0 0 24px;">
            Noosa Heads<br/>
            Sunshine Coast, QLD 4567<br/>
            Australia
          </address>
          <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:24px;">
            <a href="tel:+61424985687" style="display:inline-flex;align-items:center;gap:10px;color:#0A0A0B;text-decoration:none;font-weight:600;font-size:15px;transition:color 0.2s;" onmouseover="this.style.color='#14746F';" onmouseout="this.style.color='#0A0A0B';">
              <Icon name="phone" size={16} stroke="#14746F" /> +61 424 985 687
            </a>
            <a href="mailto:jane@click2revenue.com" style="display:inline-flex;align-items:center;gap:10px;color:#4A4A4E;text-decoration:none;font-size:14px;font-weight:500;transition:color 0.2s;" onmouseover="this.style.color='#14746F';" onmouseout="this.style.color='#4A4A4E';">
              jane@click2revenue.com
            </a>
          </div>
          <p style="font-size:13px;color:#8A8A90;margin:0;padding-top:20px;border-top:1px solid #EAEAEC;">
            Business hours: Mon–Fri 9am–6pm AEST
          </p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  @media (max-width: 760px) {
    .offices-grid { grid-template-columns: 1fr !important; }
    section:first-child { padding: 110px 18px 56px !important; }
  }
</style>
