---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
import Icon from '../components/Icon.astro';

const services = [
  { icon: 'zap',       name: 'AI Sales Automation',            desc: 'Every lead followed up. Every call answered. From first enquiry to signed contract, your sales process runs on AI.',                      href: '/services/ai-sales-automation' },
  { icon: 'search-ai', name: 'Show Up on ChatGPT',             desc: 'When customers ask ChatGPT, Google AI, or Perplexity for a recommendation, your business comes up.',                                      href: '/services/show-up-on-chatgpt' },
  { icon: 'target',    name: 'Qualified Leads',                desc: 'Google and Meta ads that close the loop between sales outcomes and the ad platform. Lead quality keeps improving, budget stays the same.',href: '/services/qualified-leads' },
  { icon: 'browser',   name: 'A Website That Sells',           desc: 'Conversion-focused. Booking-ready. AI search optimised from day one. Live in about a week.',                                              href: '/services/website-that-sells' },
  { icon: 'cog',       name: 'AI Business Process Automation', desc: 'Quoting, hiring, reporting, compliance. Anything your team does more than once the same way can run on AI.',                               href: '/services/ai-business-process-automation' },
];

const industries = [
  { icon: 'wrench',   name: 'Home Services',         sub: 'Plumbing · Electrical · HVAC · Roofing',    img: '/industries/home-services.jpg',      href: '/industries/home-services' },
  { icon: 'building', name: 'Commercial & Facility', sub: 'Strata · Cleaning · Grounds · Waste',       img: '/industries/commercial-facility.jpg',href: '/industries/commercial-facility' },
  { icon: 'glass',    name: 'Hospitality',           sub: 'Hotels · Venues · Restaurants · Tourism',   img: '/industries/hospitality.jpg',        href: '/industries/hospitality' },
  { icon: 'chart',    name: 'Financial Services',    sub: 'Accountants · Brokers · Advisers',          img: '/industries/financial-services.jpg', href: '/industries/financial-services' },
  { icon: 'factory',  name: 'Manufacturing',         sub: 'Industrial · Equipment · B2B Services',     img: '/industries/manufacturing.jpg',      href: '/industries/manufacturing-industrial' },
];

const problemStats = [
  { n: '78%',    t: 'of customers hire the first business that calls them back. If you\'re answering Monday morning, you already lost.' },
  { n: '71%',    t: 'of inbound leads get zero follow-up calls. You paid to generate them. They evaporated.' },
  { n: '21×',    t: 'more likely to qualify a lead if you respond in 5 minutes vs. 30. Speed decides it.' },
  { n: '6 to 8', t: 'touches is how many follow-ups it takes to close most service jobs. Your team does two. AI does all eight.' },
];

const promise = [
  { icon: 'shield', title: 'No lock-in',          body: 'Month-to-month after the 90-day build. Leave with 30 days notice.' },
  { icon: 'eye',    title: 'Full visibility',     body: 'Every dollar tracked from ad spend to closed sale. No vanity metrics.' },
  { icon: 'filter', title: 'Quality, not volume', body: 'Lead quality metrics reported alongside lead count every month.' },
  { icon: 'users',  title: 'Real humans',         body: 'AU and US business hours. Named account lead. Not a ticketing system.' },
];

const janeStats = [
  { n: '14+',   l: 'Years in strategic marketing' },
  { n: '$70M+', l: 'Client revenue tracked' },
  { n: '$3M+',  l: 'Marketing budgets managed' },
  { n: '3',     l: 'Languages. EN, ES, RU' },
];
---

<BaseLayout
  title="AI Marketing & Sales Automation for Service Businesses | Click2Revenue"
  description="Click2Revenue helps AU and US service businesses grow with AI sales automation, qualified leads, and AI search optimisation. Free strategy call."
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Click2Revenue",
    "description": "AI marketing and sales automation agency for service businesses in Australia and the United States.",
    "url": "https://click2revenue.com",
    "logo": "https://click2revenue.com/logo.png",
    "image": "https://click2revenue.com/og-default.png",
    "telephone": ["+61-424-985-687", "+1-925-290-9985"],
    "email": "jane@click2revenue.com",
    "priceRange": "$$",
    "address": [
      { "@type": "PostalAddress", "streetAddress": "Noosa Heads", "addressLocality": "Sunshine Coast", "addressRegion": "Queensland", "postalCode": "4567", "addressCountry": "AU" },
      { "@type": "PostalAddress", "streetAddress": "16192 Coastal Highway", "addressLocality": "Lewes", "addressRegion": "Delaware", "postalCode": "19958", "addressCountry": "US" }
    ],
    "areaServed": ["AU", "US"],
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "09:00", "closes": "18:00" }
    ],
    "sameAs": ["https://linkedin.com/company/click2revenue"]
  })} />

  <!-- ═══════════════════════════════════════════ HERO -->
  <section class="hero-section" style="position:relative;background:#FAFAF7;overflow:hidden;padding:120px 24px 80px;">
    <div aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;overflow:hidden;">
      <div style="position:absolute;top:-180px;right:-120px;width:900px;height:900px;background:radial-gradient(circle,rgba(153,226,180,0.28) 0%,rgba(153,226,180,0.08) 30%,transparent 60%);border-radius:50%;filter:blur(20px);"></div>
      <div style="position:absolute;top:200px;left:-200px;width:700px;height:700px;background:radial-gradient(circle,rgba(20,116,111,0.08) 0%,transparent 55%);border-radius:50%;filter:blur(20px);"></div>
    </div>

    <div style="position:relative;max-width:1240px;margin:0 auto;">

      <div style="display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:32px;" class="reveal">
        <span style="display:inline-block;width:6px;height:6px;background:#14746F;border-radius:50%;box-shadow:0 0 0 4px rgba(20,116,111,0.12);"></span>
        <span style="font-size:13px;color:#4A4A4E;font-weight:500;letter-spacing:-0.005em;">Trusted by 110+ service businesses across AU and US</span>
      </div>

      <div style="max-width:920px;margin:0 auto;text-align:center;" class="reveal">
        <h1 style="font-size:clamp(38px,6.2vw,84px);font-weight:800;color:#0A0A0B;line-height:0.98;letter-spacing:-0.045em;margin:0 0 24px;">
          Every missed call is a<br/>
          <span style="color:#14746F;">sale your competitor</span><br/>
          just made.
        </h1>
        <p style="font-size:clamp(16px,1.5vw,19px);color:#4A4A4E;line-height:1.55;margin:0 auto 36px;max-width:620px;font-weight:400;letter-spacing:-0.01em;">
          An AI-powered revenue system for service businesses. Book more appointments, lose fewer leads, track every dollar from the first ad to the closed sale.
        </p>

        <div style="display:flex;gap:12px;justify-content:center;align-items:center;flex-wrap:wrap;margin-bottom:52px;" class="hero-cta-row">
          <a href="#full-form-anchor" class="btn-primary">
            Get my free audit
            <Icon name="arrow-right" size={16} />
          </a>
          <a href="#services" class="btn-secondary">See how it works</a>
        </div>
      </div>

      <!-- Desktop product preview — hidden on mobile -->
      <div style="max-width:1080px;margin:0 auto;position:relative;" class="reveal hero-preview-wrap desktop-only">
        <div aria-hidden="true" style="position:absolute;inset:0;background:radial-gradient(ellipse at center,rgba(20,116,111,0.18) 0%,transparent 60%);filter:blur(40px);transform:translateY(40px) scale(0.9);"></div>

        <div style="position:relative;background:white;border-radius:22px;border:1px solid rgba(234,234,236,0.8);box-shadow:0 24px 80px rgba(10,10,11,0.10), 0 4px 12px rgba(10,10,11,0.04);overflow:hidden;">
          <div style="display:flex;align-items:center;gap:8px;padding:14px 18px;border-bottom:1px solid #EAEAEC;background:#FAFAF7;">
            <div style="display:flex;gap:6px;">
              <span style="width:11px;height:11px;border-radius:50%;background:#FF5F57;"></span>
              <span style="width:11px;height:11px;border-radius:50%;background:#FEBC2E;"></span>
              <span style="width:11px;height:11px;border-radius:50%;background:#28C840;"></span>
            </div>
            <div style="flex:1;margin-left:12px;padding:5px 14px;background:white;border-radius:6px;border:1px solid #EAEAEC;font-size:11.5px;color:#8A8A90;text-align:left;letter-spacing:-0.005em;">
              app.click2revenue.com / pipeline
            </div>
            <span style="font-size:11px;color:#4A4A4E;font-weight:500;display:flex;align-items:center;gap:6px;">
              <span style="display:inline-block;width:6px;height:6px;border-radius:50%;background:#28C840;box-shadow:0 0 0 3px rgba(40,200,64,0.15);"></span>
              AI Active
            </span>
          </div>

          <div style="display:grid;grid-template-columns:1fr 1.4fr 1fr;gap:0;min-height:340px;">
            <div style="padding:22px 20px;border-right:1px solid #EAEAEC;">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
                <p style="font-size:11px;font-weight:600;color:#8A8A90;letter-spacing:0.05em;text-transform:uppercase;margin:0;">Pipeline</p>
                <span style="font-size:11px;color:#8A8A90;">Today</span>
              </div>
              {[
                { stage: 'New leads', count: '47', color: '#14746F' },
                { stage: 'Contacted', count: '32', color: '#248277' },
                { stage: 'Qualified', count: '18', color: '#56AB91' },
                { stage: 'Booked',    count: '12', color: '#99E2B4' },
              ].map(r => (
                <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid #F0F0F2;">
                  <div style="display:flex;align-items:center;gap:10px;">
                    <span style={`display:inline-block;width:8px;height:8px;border-radius:50%;background:${r.color};`}></span>
                    <span style="font-size:13px;color:#0A0A0B;font-weight:500;">{r.stage}</span>
                  </div>
                  <span style="font-size:13px;color:#4A4A4E;font-weight:600;">{r.count}</span>
                </div>
              ))}
              <div style="margin-top:16px;padding:12px;background:#FAFAF7;border-radius:8px;">
                <p style="font-size:10px;color:#8A8A90;margin:0 0 6px;letter-spacing:0.05em;text-transform:uppercase;font-weight:600;">Today's revenue</p>
                <p style="font-weight:700;font-size:22px;color:#0A0A0B;margin:0;letter-spacing:-0.025em;">$4,230</p>
                <p style="font-size:11px;color:#14746F;margin:4px 0 0;font-weight:600;">+24% vs last week</p>
              </div>
            </div>

            <div style="padding:22px 24px;border-right:1px solid #EAEAEC;display:flex;flex-direction:column;">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;">
                <div style="display:flex;align-items:center;gap:10px;">
                  <div style="width:32px;height:32px;border-radius:8px;background:linear-gradient(135deg,#14746F 0%,#56AB91 100%);display:flex;align-items:center;justify-content:center;color:white;">
                    <Icon name="zap" size={16} strokeWidth={2} />
                  </div>
                  <div style="line-height:1.2;">
                    <p style="font-size:12.5px;font-weight:600;color:#0A0A0B;margin:0;letter-spacing:-0.005em;">C2R AI Assistant</p>
                    <p style="font-size:10.5px;color:#14746F;margin:2px 0 0;font-weight:500;">● Responding to Sarah M.</p>
                  </div>
                </div>
                <span style="font-size:10.5px;color:#8A8A90;">0:12s</span>
              </div>

              <div style="flex:1;display:flex;flex-direction:column;gap:10px;">
                <div style="align-self:flex-start;max-width:82%;padding:10px 14px;background:#F6F5F0;border-radius:14px 14px 14px 4px;">
                  <p style="font-size:12.5px;color:#0A0A0B;margin:0;line-height:1.45;">Hey, need a plumber for tomorrow. Is anyone available?</p>
                </div>
                <div style="align-self:flex-end;max-width:82%;padding:10px 14px;background:#14746F;border-radius:14px 14px 4px 14px;">
                  <p style="font-size:12.5px;color:white;margin:0;line-height:1.45;">Morning. Yes. We have 10am or 2pm tomorrow. What's the job?</p>
                </div>
                <div style="align-self:flex-start;max-width:82%;padding:10px 14px;background:#F6F5F0;border-radius:14px 14px 14px 4px;">
                  <p style="font-size:12.5px;color:#0A0A0B;margin:0;line-height:1.45;">Blocked kitchen drain. 2pm works.</p>
                </div>
                <div style="align-self:flex-end;max-width:85%;padding:10px 14px;background:#14746F;border-radius:14px 14px 4px 14px;">
                  <p style="font-size:12.5px;color:white;margin:0;line-height:1.45;">Booked. Confirmation sent. Mike will be there 2pm.</p>
                </div>
              </div>

              <div style="margin-top:16px;padding-top:14px;border-top:1px solid #F0F0F2;display:flex;align-items:center;justify-content:space-between;gap:8px;flex-wrap:wrap;">
                <span style="font-size:11px;color:#14746F;font-weight:600;display:inline-flex;align-items:center;gap:6px;">
                  <Icon name="check" size={12} stroke="#14746F" /> Lead qualified. Appointment booked.
                </span>
                <span style="font-size:10.5px;color:#8A8A90;">Auto-synced to CRM</span>
              </div>
            </div>

            <div style="padding:22px 20px;display:flex;flex-direction:column;gap:14px;">
              <p style="font-size:11px;font-weight:600;color:#8A8A90;letter-spacing:0.05em;text-transform:uppercase;margin:0;">Last 24h</p>
              {[
                { n: '47',  l: 'New leads' },
                { n: '12s', l: 'Avg response time' },
                { n: '98%', l: 'Follow-up rate' },
              ].map(s => (
                <div>
                  <p style="font-weight:700;font-size:30px;color:#0A0A0B;margin:0;letter-spacing:-0.035em;line-height:1;">{s.n}</p>
                  <p style="font-size:11.5px;color:#4A4A4E;margin:4px 0 0;">{s.l}</p>
                </div>
              ))}

              <div style="margin-top:auto;padding-top:14px;border-top:1px solid #F0F0F2;">
                <p style="font-size:10.5px;color:#8A8A90;margin:0 0 8px;font-weight:500;">This week</p>
                <svg viewBox="0 0 120 40" style="width:100%;height:40px;">
                  <defs>
                    <linearGradient id="sparkfill" x1="0" x2="0" y1="0" y2="1">
                      <stop offset="0%" stop-color="#14746F" stop-opacity="0.25"/>
                      <stop offset="100%" stop-color="#14746F" stop-opacity="0"/>
                    </linearGradient>
                  </defs>
                  <path d="M0,30 L20,26 L40,22 L60,24 L80,14 L100,10 L120,6 L120,40 L0,40 Z" fill="url(#sparkfill)"/>
                  <path d="M0,30 L20,26 L40,22 L60,24 L80,14 L100,10 L120,6" stroke="#14746F" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- MOBILE hero visual — clean, focused, mobile-native -->
      <div class="mobile-only mobile-hero-visual reveal">
        <!-- Main card: AI in action -->
        <div style="background:white;border:1px solid #EAEAEC;border-radius:20px;padding:22px;box-shadow:0 12px 40px rgba(10,10,11,0.06);">

          <!-- AI header -->
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:18px;">
            <div style="width:40px;height:40px;border-radius:10px;background:linear-gradient(135deg,#14746F 0%,#56AB91 100%);display:flex;align-items:center;justify-content:center;color:white;flex-shrink:0;">
              <Icon name="zap" size={20} strokeWidth={2} />
            </div>
            <div style="line-height:1.2;flex:1;min-width:0;">
              <p style="font-size:14px;font-weight:600;color:#0A0A0B;margin:0;letter-spacing:-0.01em;">C2R AI Assistant</p>
              <p style="font-size:12px;color:#14746F;margin:3px 0 0;font-weight:500;display:flex;align-items:center;gap:6px;">
                <span style="display:inline-block;width:6px;height:6px;border-radius:50%;background:#28C840;box-shadow:0 0 0 3px rgba(40,200,64,0.15);"></span>
                Responding in 12 seconds
              </p>
            </div>
          </div>

          <!-- Quote -->
          <div style="padding:14px 16px;background:#FAFAF7;border:1px solid #EAEAEC;border-radius:12px;margin-bottom:16px;">
            <p style="font-size:14px;color:#0A0A0B;margin:0;line-height:1.55;">
              "Booked. Mike will be there at 2pm. Confirmation sent."
            </p>
          </div>

          <!-- Result pills -->
          <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <span style="padding:6px 12px;background:rgba(153,226,180,0.25);color:#14746F;font-size:12px;font-weight:600;border-radius:99px;display:inline-flex;align-items:center;gap:5px;">
              <Icon name="check" size={12} stroke="#14746F" /> Lead qualified
            </span>
            <span style="padding:6px 12px;background:rgba(153,226,180,0.25);color:#14746F;font-size:12px;font-weight:600;border-radius:99px;display:inline-flex;align-items:center;gap:5px;">
              <Icon name="check" size={12} stroke="#14746F" /> Appointment booked
            </span>
          </div>
        </div>

        <!-- Supporting stats row -->
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:12px;">
          {[
            { n: '47',  l: 'Leads today' },
            { n: '12s', l: 'Avg response' },
            { n: '98%', l: 'Follow-up rate' },
          ].map(s => (
            <div style="background:white;border:1px solid #EAEAEC;border-radius:14px;padding:14px 10px;text-align:center;">
              <p style="font-weight:700;font-size:22px;color:#0A0A0B;margin:0;letter-spacing:-0.025em;line-height:1;">{s.n}</p>
              <p style="font-size:10.5px;color:#8A8A90;margin:6px 0 0;line-height:1.3;">{s.l}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Certified partners row -->
      <div style="margin-top:100px;text-align:center;" class="reveal trust-row-wrap">
        <p style="font-size:11px;letter-spacing:0.2em;text-transform:uppercase;color:#8A8A90;font-weight:500;margin:0 0 24px;">Certified partners</p>
        <div style="display:flex;align-items:center;justify-content:center;gap:32px 48px;flex-wrap:wrap;" class="trust-row">
          {['Google Partner', 'Meta Business Partner', 'HubSpot', 'Salesforce', 'Semrush', 'Zoho', 'Go High Level'].map(p => (
            <span style="font-weight:600;font-size:14px;color:#8A8A90;letter-spacing:-0.01em;transition:color 0.2s;"
                  onmouseover="this.style.color='#0A0A0B';"
                  onmouseout="this.style.color='#8A8A90';">{p}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ STATS -->
  <section style="background:white;padding:110px 24px 100px;border-top:1px solid #EAEAEC;">
    <div style="max-width:1200px;margin:0 auto;">
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:56px;" class="stats-grid">
        {[
          { n: '110+',   l: 'Service businesses scaled',  sub: 'Across 3 continents' },
          { n: '$70M+',  l: 'Tracked client revenue',     sub: 'Since 2017' },
          { n: '5,000+', l: 'Appointments delivered',     sub: 'Via AI automation' },
        ].map(s => (
          <div class="reveal stats-cell">
            <p style="font-weight:700;font-size:clamp(44px,5.5vw,72px);color:#0A0A0B;margin:0;line-height:0.95;letter-spacing:-0.045em;">{s.n}</p>
            <p style="font-size:15px;color:#0A0A0B;margin:16px 0 4px;font-weight:600;letter-spacing:-0.01em;">{s.l}</p>
            <p style="font-size:13px;color:#8A8A90;margin:0;">{s.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ PROBLEM -->
  <section style="background:#F6F5F0;padding:110px 24px;">
    <div style="max-width:1100px;margin:0 auto;">
      <div class="reveal" style="max-width:760px;margin-bottom:64px;">
        <h2 style="font-size:clamp(36px,5vw,64px);color:#0A0A0B;margin:0;line-height:1.0;letter-spacing:-0.035em;">
          This is the <span style="color:#14746F;">maths</span><br/>nobody wants to do.
        </h2>
      </div>

      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:#EAEAEC;border:1px solid #EAEAEC;border-radius:20px;overflow:hidden;" class="problem-grid">
        {problemStats.map(s => (
          <div class="reveal" style="padding:40px 36px;background:white;">
            <p style="font-weight:700;font-size:clamp(44px,5vw,64px);color:#0A0A0B;margin:0 0 14px;line-height:0.95;letter-spacing:-0.04em;">{s.n}</p>
            <p style="font-size:15px;color:#4A4A4E;line-height:1.6;margin:0;font-weight:400;letter-spacing:-0.005em;">{s.t}</p>
          </div>
        ))}
      </div>

      <!-- CTA after Problem -->
      <div class="reveal" style="text-align:center;margin-top:52px;">
        <a href="#full-form-anchor" class="btn-primary">
          Let's fix this together
          <Icon name="arrow-right" size={16} />
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ EMPATHY -->
  <section style="background:white;padding:120px 24px;">
    <div style="max-width:880px;margin:0 auto;text-align:center;" class="reveal">
      <h2 style="font-size:clamp(32px,4.8vw,52px);color:#0A0A0B;margin:0 0 20px;line-height:1.1;letter-spacing:-0.035em;">
        Your revenue should be as <span style="color:#14746F;">predictable</span> as your power bill.
      </h2>
      <p style="font-size:18px;color:#4A4A4E;line-height:1.6;margin:0;font-weight:400;max-width:600px;margin-inline:auto;letter-spacing:-0.01em;">
        You shouldn't have to wonder where next month's jobs are coming from. With the right AI system in place, you don't.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ SERVICES — redesigned cards -->
  <section id="services" style="background:#FAFAF7;padding:110px 24px;position:relative;overflow:hidden;">
    <div aria-hidden="true" style="position:absolute;top:200px;right:-150px;width:500px;height:500px;background:radial-gradient(circle,rgba(153,226,180,0.12) 0%,transparent 60%);border-radius:50%;pointer-events:none;"></div>

    <div style="position:relative;max-width:1240px;margin:0 auto;">
      <div class="reveal" style="max-width:720px;margin:0 auto 64px;text-align:center;">
        <span class="label">What we build</span>
        <h2 style="font-size:clamp(32px,4.8vw,56px);color:#0A0A0B;margin:0;line-height:1.05;letter-spacing:-0.035em;">
          One system. <span style="color:#14746F;">Five services.</span>
        </h2>
