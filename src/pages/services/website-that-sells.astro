---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UniversalBottom from '../../components/UniversalBottom.astro';
import FAQSection from '../../components/FAQSection.astro';
import Icon from '../../components/Icon.astro';

const pains = [
  { title: "It looks fine. It just doesn't get anyone to call.", body: "Most small business websites were built to look professional, not to convert visitors into leads. No clear call to action. Slow load speed on mobile. A contact page buried in the footer. The visitors come, they read a paragraph, and they leave. The designer got paid. The phone didn't ring." },
  { title: "You're still taking bookings over the phone.",       body: "Every booking that comes through a phone call is a booking that almost didn't happen. The customer called during a job, left a voicemail, waited, got a callback, and maybe booked. Or got impatient and called someone else. Online booking removes every one of those friction points. It takes bookings at 11pm when the business is closed and the customer is ready to commit." },
  { title: "The build took four months. By launch, it was already out of date.", body: "Website projects stretch. Revisions pile up. Launch gets pushed back. Then the booking system still isn't connected. And when something needs changing after launch, there are two revision rounds, then the agency is on to the next project. Most of those problems come from building sites by hand, the slow way. AI tools cut build time to about a week and make ongoing changes fast." },
];

const steps = [
  { n: '01', t: 'The brief runs before a single page gets built.',    b: "Before design starts, the right questions get answered: who the visitors are, what they need to see before they book, what makes this business the obvious choice, and what friction is stopping them from calling. The strategy brief becomes the blueprint." },
  { n: '02', t: 'A conversion-focused site gets built for speed.',    b: "The design serves the outcome. Every headline, every button, every image gets placed to move a visitor toward an enquiry or a booking. The site loads fast on mobile where most visitors are. The visual reflects the brand. The structure reflects buyer psychology." },
  { n: '03', t: 'Online booking and payments connect.',               b: "A booking system goes live so customers can book directly from the site, at any hour. Payment processing connects for deposits or full payments at time of booking. Confirmation and reminder messages go out automatically. The calendar fills without a single phone call." },
  { n: '04', t: 'The site gets built for AI search from day one.',    b: "Structure, headings, localised content, and metadata get set up so AI engines like ChatGPT, Google AI, and Perplexity can read the site clearly and start recommending the business. Built in from the start, not retrofitted later." },
];

const features = [
  { icon: 'target',   name: 'Conversion-Focused Design',       desc: "Every element — headline, layout, images, calls to action — exists to move a visitor toward an enquiry or a booking. Clean, fast, and structured for buyer psychology." },
  { icon: 'phone',    name: 'Mobile-First Build',              desc: "Most visitors arrive on a phone. The site loads in under 3 seconds on mobile, buttons are thumb-sized, and the booking flow works without pinching or zooming." },
  { icon: 'check',    name: 'Online Booking Integration',      desc: "Customers book directly from the site, 24/7. Calendar availability, automated confirmations, and reminder sequences connect without manual input." },
  { icon: 'shield',   name: 'Payment Processing',              desc: "Deposits or full payments taken at time of booking. Payment confirmation goes to the customer automatically. No chasing invoices for the booking." },
  { icon: 'layers',   name: 'Enquiry Forms + Lead Capture',    desc: "Short, friction-low forms on every relevant page. Every submission goes straight into the CRM. No lead falls into an inbox and gets forgotten." },
  { icon: 'loop',     name: 'Click2Revenue Platform Integration', desc: "Every website lead, form submission, booking, or phone call, flows directly into the pipeline. The lead gets a follow-up sequence automatically." },
  { icon: 'zap',      name: 'Speed Optimisation',              desc: "Images compressed, code streamlined, hosting configured for fast load times across AU and US. Google scores fast. So do visitors." },
  { icon: 'search-ai',name: 'AI Search Optimisation (Built In)',desc: "Site structure, headings, localised service and location pages, and metadata set up for ChatGPT, Google AI, and Perplexity visibility from day one." },
  { icon: 'chart',    name: 'Analytics + Tracking Setup',       desc: "Google Analytics and conversion tracking go live with the site. Lead sources, page performance, and form conversion rates are visible from the first week." },
  { icon: 'cog',      name: 'Hosting + Domain Setup',           desc: "Hosting configured, domain connected, SSL certificate active, business email set up if needed. The technical side handled end to end." },
  { icon: 'browser',  name: 'Content Direction',                desc: "Headline copy, page structure, and offer framing provided for every page. The copy gets reviewed and refined before launch." },
  { icon: 'sparkle',  name: 'Ongoing Changes, No Revision Limits',desc: "The site doesn't freeze at launch. Pricing changes, new services, seasonal offers — updated fast using AI tools. No two-revision cap." },
];
const faqs = [
  { q: `How can you build a website in a week — won't it be low quality?`, a: `The speed comes from AI tools that handle the heavy lifting — layout generation, content formatting, code output. What used to take a developer four weeks of manual work takes a fraction of the time. The strategy and structure still get done properly before build starts — the brief, the conversion flow, the offer hierarchy. Speed doesn't mean shortcuts. It means the slow parts got automated so the thinking parts get the time they deserve.` },
  { q: `Who writes the copy for the website?`, a: `The copy gets provided as part of the service — headline, offer framing, page structure, calls to action. It gets written specifically for the business and the target customer, not pulled from a template. If the business already has copy it's happy with, that gets used. If not, it gets written fresh. Either way, the copy gets reviewed before build starts.` },
  { q: `What happens if I need changes after launch?`, a: `Changes happen fast. There's no two-revision cap and no waiting weeks for something simple. Pricing updates, new service pages, seasonal offers, location additions — handled as they come up. The tools that made the build fast make ongoing changes fast too. The site stays current because it can.` },
  { q: `Does the website include hosting?`, a: `Yes. Hosting gets configured as part of the build — domain connected, SSL certificate active, fast load times configured. The hosting cost is included in the ongoing monthly fee. Nothing to set up separately.` },
  { q: `Can you work with my existing domain name?`, a: `Yes. The existing domain gets pointed to the new site. If the old site is staying live somewhere else temporarily (for language/market separation, for example), a subdomain or separate setup gets organised. Domain transfer and DNS configuration are handled during the go-live process.` },
];

---

<BaseLayout
  title="Website Design for Service Businesses — Live in a Week | Click2Revenue"
  description="Conversion-focused websites with online booking, payments, and AI search visibility. Live in about a week. Built for service businesses in AU and the US."
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org", "@type": "Service",
    "name": "A Website That Sells",
    "description": "Conversion-focused websites with online booking, payments, and AI search visibility. Live in about a week.",
    "url": "https://click2revenue.com/services/website-that-sells",
    "provider": { "@type": "Organization", "name": "Click2Revenue", "url": "https://click2revenue.com" },
    "areaServed": ["AU", "US"], "serviceType": "Website Design and Development"
  })} />
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://click2revenue.com/" },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://click2revenue.com/services" },
      { "@type": "ListItem", "position": 3, "name": "A Website That Sells", "item": "https://click2revenue.com/services/website-that-sells" }
    ]
  })} />

  <!-- HERO -->
  <section style="background:#FAFAF7;padding:140px 24px 80px;position:relative;overflow:hidden;">
    <div aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;overflow:hidden;">
      <div style="position:absolute;top:-180px;right:-120px;width:900px;height:900px;background:radial-gradient(circle,rgba(153,226,180,0.22) 0%,transparent 60%);border-radius:50%;filter:blur(20px);"></div>
    </div>
    <div style="position:relative;max-width:1100px;margin:0 auto;">
      <div style="max-width:880px;margin:0 auto;text-align:center;">
        <span class="label">A Website That Sells</span>
        <h1 style="font-size:clamp(38px,5.6vw,76px);font-weight:800;color:#0A0A0B;margin:0 0 24px;line-height:0.98;letter-spacing:-0.045em;">
          Your website should be your best salesperson. <span style="color:#14746F;">Right now it's probably a digital brochure.</span>
        </h1>
        <p style="font-size:clamp(17px,1.6vw,20px);color:#4A4A4E;line-height:1.55;margin:0 auto 36px;max-width:680px;font-weight:400;letter-spacing:-0.01em;">
          A conversion-focused website with online booking, payments, and AI search visibility. Live in about a week, with ongoing changes as fast as the business moves.
        </p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;" class="hero-cta-row">
          <a href="#full-form-anchor" class="btn-primary">Get my free website audit <Icon name="arrow-right" size={16} /></a>
          <a href="#features" class="btn-secondary">See what's included</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLEM -->
  <section style="background:white;padding:110px 24px;">
    <div style="max-width:1100px;margin:0 auto;">
      <div class="reveal" style="max-width:760px;margin-bottom:56px;text-align:center;margin-inline:auto;">
        <h2 style="font-size:clamp(32px,4.5vw,54px);color:#0A0A0B;margin:0;line-height:1.05;letter-spacing:-0.035em;">
          Most websites don't convert. <span style="color:#14746F;">They just exist.</span>
        </h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;" class="pain-grid">
        {pains.map(p => (
          <div class="reveal" style="padding:36px 32px;background:#FAFAF7;border:1px solid #EAEAEC;border-radius:16px;">
            <h3 style="font-weight:700;font-size:19px;color:#14746F;margin:0 0 14px;letter-spacing:-0.02em;line-height:1.3;">{p.title}</h3>
            <p style="font-size:14.5px;color:#4A4A4E;line-height:1.7;margin:0;letter-spacing:-0.005em;">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section style="background:#F6F5F0;padding:110px 24px;">
    <div style="max-width:1100px;margin:0 auto;">
      <div class="reveal" style="text-align:center;max-width:700px;margin:0 auto 64px;">
        <span class="label">How it works</span>
        <h2 style="font-size:clamp(30px,4.5vw,50px);color:#0A0A0B;margin:0;line-height:1.05;letter-spacing:-0.035em;">
          Fast, focused, <span style="color:#14746F;">live.</span>
        </h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;" class="steps-grid-4">
        {steps.map(s => (
          <div class="reveal" style="padding:32px 26px;background:white;border:1px solid #EAEAEC;border-radius:16px;">
            <p style="font-weight:700;font-size:14px;color:#14746F;margin:0 0 18px;letter-spacing:0.05em;">{s.n}</p>
            <h3 style="font-weight:700;font-size:17px;margin:0 0 12px;color:#0A0A0B;letter-spacing:-0.02em;line-height:1.25;">{s.t}</h3>
            <p style="font-size:13.5px;color:#4A4A4E;line-height:1.65;margin:0;letter-spacing:-0.005em;">{s.b}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features" style="background:white;padding:110px 24px;">
    <div style="max-width:1240px;margin:0 auto;">
      <div class="reveal" style="text-align:center;max-width:720px;margin:0 auto 56px;">
        <span class="label">What's included</span>
        <h2 style="font-size:clamp(30px,4.5vw,50px);color:#0A0A0B;margin:0;line-height:1.05;letter-spacing:-0.035em;">
          Everything a converting website<br class="br-desktop"/> needs. <span style="color:#14746F;">Nothing disconnected.</span>
        </h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;" class="feat-grid-4">
        {features.map(f => (
          <div class="reveal" style="padding:26px 22px;background:#FAFAF7;border:1px solid #EAEAEC;border-radius:14px;">
            <div style="display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:9px;background:white;border:1px solid #EAEAEC;color:#14746F;margin-bottom:14px;">
              <Icon name={f.icon} size={18} />
            </div>
            <h3 style="font-weight:700;font-size:15px;margin:0 0 8px;color:#0A0A0B;letter-spacing:-0.02em;line-height:1.3;">{f.name}</h3>
            <p style="font-size:13px;color:#4A4A4E;line-height:1.6;margin:0;letter-spacing:-0.005em;">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CASE STUDY — Craig Davis with Fireshot -->
  <section style="background:#F6F5F0;padding:110px 24px;">
    <div style="max-width:1200px;margin:0 auto;">
      <div class="reveal" style="background:white;border:1px solid #EAEAEC;border-radius:22px;padding:56px;">
        <div style="display:grid;grid-template-columns:1fr 1.2fr;gap:56px;align-items:center;" class="cs-grid">
          <div>
            <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px;">
              <div style="width:60px;height:60px;border-radius:50%;overflow:hidden;flex-shrink:0;">
                <img src="/craig-davies.jpg" alt="Craig Davis" style="width:100%;height:100%;object-fit:cover;"/>
              </div>
              <div>
                <p style="font-size:14px;font-weight:600;color:#0A0A0B;margin:0;letter-spacing:-0.01em;">Craig Davis</p>
                <p style="font-size:12.5px;color:#8A8A90;margin:2px 0 0;">Owner, Surf Hire Noosa</p>
              </div>
            </div>
            <!-- Real website screenshot -->
            <div style="border-radius:14px;overflow:hidden;border:1px solid #EAEAEC;box-shadow:0 16px 40px rgba(10,10,11,0.1);">
              <img src="/craig-website.jpg" alt="Surf Hire Noosa website" style="width:100%;height:auto;display:block;"/>
            </div>
            <p style="margin:12px 0 0;font-size:11.5px;color:#8A8A90;text-align:center;font-style:italic;">surfhirenoosa.com.au &mdash; live in 2 weeks.</p>
          </div>
          <div>
            <span style="display:inline-block;padding:5px 12px;background:#FAFAF7;border:1px solid #EAEAEC;border-radius:99px;color:#14746F;font-size:11px;letter-spacing:0.15em;font-weight:700;text-transform:uppercase;margin-bottom:18px;">Real result</span>
            <h2 style="font-size:clamp(26px,3.2vw,36px);color:#0A0A0B;margin:0 0 20px;line-height:1.1;letter-spacing:-0.025em;">
              No website on Tuesday. Online bookings running <span style="color:#14746F;">by Friday.</span>
            </h2>
            <p style="font-size:15.5px;color:#4A4A4E;line-height:1.7;margin:0 0 20px;letter-spacing:-0.005em;">
              Craig runs Surf Hire Noosa on the Sunshine Coast. No website. Customers found him through walk-in traffic and Google My Business. Bookings came through phone calls and in person. Every booking required a conversation. Peak season, it was chaos.
            </p>
            <p style="font-size:15.5px;color:#4A4A4E;line-height:1.7;margin:0 0 24px;letter-spacing:-0.005em;">
              A clean, fast website went live in two weeks, structured for conversion and AI search from day one. An online booking system connected directly to his calendar. Customers choose a board, pick a time, pay a deposit, and get a confirmation, all without Craig picking up the phone. Bookings that used to come in by phone or walk-in now happen online, at night, while Craig is on the water.
            </p>
            <blockquote style="padding:18px 24px;background:#FAFAF7;border-left:3px solid #14746F;border-radius:10px;margin:0 0 24px;font-style:italic;font-size:16px;color:#0A0A0B;line-height:1.6;letter-spacing:-0.005em;">
              "Two weeks. That's all it took. I went from chasing customers to having them book themselves."
              <span style="display:block;margin-top:10px;font-style:normal;font-size:13px;color:#8A8A90;">Craig Davis, Owner, Surf Hire Noosa</span>
            </blockquote>
            <div style="display:flex;flex-wrap:wrap;gap:10px;">
              {[
                'Zero online presence → automated bookings',
                '24/7 availability, booking volume up',
                'Phone bookings replaced entirely',
              ].map(r => (
                <span style="padding:7px 14px;background:#FAFAF7;border:1px solid #EAEAEC;border-radius:99px;color:#14746F;font-size:12.5px;font-weight:600;">{r}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══ FAQ ═══ -->
  <FAQSection
    kicker="Frequently asked"
    heading="A Website That Sells"
    accent="questions answered"
    faqs={faqs}
    background="white"
  />

  <UniversalBottom
    service="website_that_sells"
    source="service_page"
    guaranteeText="If the site isn't live, tested, and taking bookings within 7 days of receiving the brief, the build is on us. No small print."
    formHeadline="Ready for a website that actually books jobs?"
    formSubheadline="A free audit of your current site and booking flow runs within 24 hours. Our AI replies instantly. A human follows up during business hours."
  />

</BaseLayout>

<style>
  @media (max-width: 1000px) {
    .pain-grid    { grid-template-columns: 1fr !important; }
    .steps-grid-4 { grid-template-columns: repeat(2, 1fr) !important; }
    .feat-grid-4  { grid-template-columns: repeat(2, 1fr) !important; }
    .cs-grid      { grid-template-columns: 1fr !important; gap: 36px !important; }
  }
  @media (max-width: 760px) {
    section:first-child { padding: 120px 18px 64px !important; }
    section { padding-left: 18px !important; padding-right: 18px !important; padding-top: 64px !important; padding-bottom: 64px !important; }
    .steps-grid-4, .feat-grid-4 { grid-template-columns: 1fr !important; }
    .hero-cta-row a { width: 100%; justify-content: center; }
    .cs-grid > div:first-child { max-width: 240px; margin: 0 auto; }
  }
</style>
