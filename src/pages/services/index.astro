---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';

const services = [
  {
    icon: 'zap',
    name: 'AI Sales Automation',
    desc: 'Every lead followed up. Every call answered. Your entire sales process, from first enquiry to signed contract, running on AI. Your team focuses on closing, not chasing.',
    cta: 'See how it works',
    href: '/services/ai-sales-automation',
  },
  {
    icon: 'search-ai',
    name: 'Show Up on ChatGPT',
    desc: 'When a local customer asks ChatGPT or Google AI for your service, your business comes up. Your website and content get optimised so AI engines recommend you. Without paid ads.',
    cta: 'Find out if you\'re visible',
    href: '/services/show-up-on-chatgpt',
  },
  {
    icon: 'target',
    name: 'Qualified Leads',
    desc: 'A complete lead generation system that closes the feedback loop between your sales outcomes and your ad platform. The system learns what your best customers look like and finds more of them over time.',
    cta: 'See how it works',
    href: '/services/qualified-leads',
  },
  {
    icon: 'browser',
    name: 'A Website That Sells',
    desc: 'A conversion-focused website with online booking, payments, and AI search visibility. Live in about a week, built to turn visitors into booked jobs. Ongoing changes as fast as the business moves.',
    cta: 'Get my free website audit',
    href: '/services/website-that-sells',
  },
  {
    icon: 'cog',
    name: 'AI Business Process Automation',
    desc: 'Quoting, hiring, reporting, compliance tracking, invoice follow-up, staff onboarding. Anything your team does more than once the same way can probably be automated. Here\'s what that looks like in practice.',
    cta: 'See what we\'ve automated',
    href: '/services/ai-business-process-automation',
  },
];
---

<BaseLayout
  title="AI Marketing & Automation Services for Service Businesses | Click2Revenue"
  description="Five AI-powered services for service businesses: sales automation, AI search, lead generation, website design, and business process automation. AU + US."
>

  <!-- HERO -->
  <section style="background:#FAFAF7;padding:140px 24px 64px;position:relative;overflow:hidden;">
    <div aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;overflow:hidden;">
      <div style="position:absolute;top:-180px;right:-120px;width:900px;height:900px;background:radial-gradient(circle,rgba(153,226,180,0.22) 0%,transparent 60%);border-radius:50%;filter:blur(20px);"></div>
    </div>
    <div style="position:relative;max-width:900px;margin:0 auto;text-align:center;">
      <span class="label">Services</span>
      <h1 style="font-size:clamp(30px,6vw,80px);font-weight:800;color:#0A0A0B;margin:0 0 20px;line-height:1.05;letter-spacing:-0.04em;text-wrap:balance;">
        Five ways to grow<br class="br-desktop"/>
        <span style="color:#14746F;">a service business</span> with AI.
      </h1>
      <p style="font-size:clamp(17px,1.6vw,20px);color:#4A4A4E;line-height:1.55;margin:0 auto;max-width:640px;font-weight:400;letter-spacing:-0.01em;">
        From the first ad to the signed contract to the automated process underneath it all. Together, they compound.
      </p>
    </div>
  </section>

  <!-- SERVICES LIST -->
  <section style="background:white;padding:80px 24px 100px;">
    <div style="max-width:1100px;margin:0 auto;display:flex;flex-direction:column;gap:16px;">
      {services.map((s, i) => (
        <a href={s.href} class="svc-row reveal">
          <div class="svc-row-icon">
            <Icon name={s.icon} size={28} />
          </div>
          <div class="svc-row-body">
            <div class="svc-row-head">
              <h3 class="svc-row-name">{s.name}</h3>
              <span class="svc-row-num">0{i + 1}</span>
            </div>
            <p class="svc-row-desc">{s.desc}</p>
            <span class="svc-row-cta">
              {s.cta}
              <Icon name="arrow-right" size={14} />
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA STRIP -->
  <section style="background:#0A0A0B;padding:80px 24px;position:relative;overflow:hidden;">
    <div aria-hidden="true" style="position:absolute;top:-200px;right:-100px;width:600px;height:600px;background:radial-gradient(circle,rgba(20,116,111,0.25) 0%,transparent 60%);border-radius:50%;filter:blur(20px);"></div>
    <div style="position:relative;max-width:800px;margin:0 auto;text-align:center;">
      <h2 style="font-size:clamp(32px,4.5vw,48px);color:white;margin:0 0 18px;line-height:1.1;letter-spacing:-0.03em;">
        Not sure which one <span style="color:#99E2B4;">fits?</span>
      </h2>
      <p style="font-size:17px;color:rgba(255,255,255,0.7);margin:0 0 32px;line-height:1.6;letter-spacing:-0.005em;">
        Book a free 30-minute strategy call. The right starting point becomes clear fast.
      </p>
      <a href="/contact" style="display:inline-flex;align-items:center;gap:8px;background:white;color:#0A0A0B;font-weight:600;font-size:15px;padding:14px 26px;border-radius:10px;text-decoration:none;transition:all 0.2s;letter-spacing:-0.005em;"
         onmouseover="this.style.background='#99E2B4';"
         onmouseout="this.style.background='white';">
        Book a free strategy call
        <Icon name="arrow-right" size={16} />
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .svc-row {
    display: flex;
    align-items: flex-start;
    gap: 28px;
    padding: 32px 36px;
    background: white;
    border: 1px solid #EAEAEC;
    border-radius: 18px;
    text-decoration: none;
    transition: all 0.25s;
  }
  .svc-row:hover {
    border-color: #0A0A0B;
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(10,10,11,0.06);
  }
  .svc-row-icon {
    width: 52px;
    height: 52px;
    border-radius: 13px;
    background: #FAFAF7;
    border: 1px solid #EAEAEC;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #14746F;
    flex-shrink: 0;
    transition: all 0.25s;
  }
  .svc-row:hover .svc-row-icon {
    background: #0A0A0B;
    border-color: #0A0A0B;
    color: white;
  }
  .svc-row-body { flex: 1; min-width: 0; }
  .svc-row-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 10px;
  }
  .svc-row-name {
    font-weight: 700;
    font-size: 22px;
    color: #0A0A0B;
    margin: 0;
    letter-spacing: -0.025em;
    line-height: 1.2;
  }
  .svc-row-num {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: #8A8A90;
    letter-spacing: 0.08em;
  }
  .svc-row-desc {
    font-size: 15px;
    color: #4A4A4E;
    line-height: 1.65;
    margin: 0 0 14px;
    font-weight: 400;
    letter-spacing: -0.005em;
    max-width: 720px;
  }
  .svc-row-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    color: #14746F;
    letter-spacing: -0.005em;
  }

  @media (max-width: 760px) {
    section:first-child { padding: 120px 18px 48px !important; }
    section { padding-left: 18px !important; padding-right: 18px !important; }
    .svc-row { flex-direction: column; gap: 18px; padding: 28px 24px; }
    .svc-row-icon { width: 44px; height: 44px; }
    .svc-row-head { flex-direction: column-reverse; align-items: flex-start; gap: 4px; }
    .svc-row-name { font-size: 20px; }
    .svc-row-num { font-size: 11px; }
  }
</style>
