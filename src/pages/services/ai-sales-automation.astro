---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UniversalBottom from '../../components/UniversalBottom.astro';
import FAQSection from '../../components/FAQSection.astro';
import Icon from '../../components/Icon.astro';

const pains = [
  { title: 'The lead that called at 7pm.',                    body: "You were on a job. They left a voicemail. By 9am the next day they'd already booked with whoever called them back first. 78% of customers hire the first business that responds. You're not losing on price, you're losing on speed." },
  { title: 'The quote that never got a second look.',         body: "You sent a detailed proposal. One follow-up email. Silence. Closed lost. The average service sale takes 6 to 8 touches to close. Most businesses do two. The gap between those numbers is where your revenue is disappearing." },
  { title: "Five tools that still don't talk to each other.", body: "Your CRM is in one tab. Your email marketing is in another. Follow-up reminders are in a spreadsheet. Booking confirmations are in your calendar. E-signatures are in DocuSign. Nothing connects. Every lead falls through a different crack." },
];

const steps = [
  { n: '01', t: 'You walk us through how your business sells.', b: "Every lead source, every touchpoint, every step from first enquiry to signed job. Your process, your language, your pricing. So the system is built for how you actually work, not a generic template." },
  { n: '02', t: 'Your AI sales system gets built and your team gets trained.', b: "The Click2Revenue Platform gets configured: pipeline stages, AI voice bot trained on your services and FAQs, SMS follow-up sequences, e-signature workflows, unified inbox. Your team gets a full walkthrough so everyone is confident on day one. Available on desktop and on the iOS and Android mobile app." },
  { n: '03', t: 'Your AI runs the sales process. You close the deals.', b: "Every new lead gets an instant response. Every quote gets followed up across 6 to 8 touches automatically. Your team steps in when a prospect is warm and ready, not to chase cold contacts. We stay on hand for ongoing support and customisation as your business grows." },
];

const features = [
  { icon: 'phone',     name: 'AI Voice Bot',                   desc: "Answers every inbound call, 24/7. Qualifies the lead, answers common questions, books a callback or appointment straight into your calendar. Trained on your services, your pricing, and your FAQs." },
  { icon: 'zap',       name: 'AI SMS Bot',                     desc: "Responds to every missed call and web enquiry within 5 minutes via SMS. Holds a conversation, qualifies the lead, and hands off to your team when they're warm. Runs day and night." },
  { icon: 'loop',      name: 'Automated Follow-Up Sequences',  desc: "Multi-touch sequences for every pipeline stage. New lead, sent quote, no response, closed lost. Day 1, 3, 7, 14. Six to eight touches, SMS and email." },
  { icon: 'layers',    name: 'CRM Pipeline',                   desc: "Every lead, every deal, every conversation in one screen. Drag-and-drop pipeline stages. No spreadsheet. No lost leads. Full visibility across your team." },
  { icon: 'browser',   name: 'Unified Inbox',                  desc: "Every message from every channel. Website form, Google Business Profile, Facebook, Instagram, SMS. One screen, one team, zero missed conversations." },
  { icon: 'check',     name: 'Appointment & Calendar Automation', desc: "Leads book directly into your calendar from SMS, your website, or a booking link. Confirmation and reminder sequences run automatically. No-shows drop." },
  { icon: 'shield',    name: 'E-Signatures',                   desc: "Send proposals, contracts, and agreements for digital signature directly from your pipeline. No DocuSign subscription. No chasing paper. Signed documents stored automatically." },
  { icon: 'sparkle',   name: 'Automated Review Requests',      desc: "After every completed job, an automated SMS goes out requesting a Google review. Timed perfectly. Personalised. Review count grows without anyone remembering to ask." },
  { icon: 'chart',     name: 'Reporting Dashboard',            desc: "Lead sources, response times, pipeline value, conversion rates, and revenue attribution. All in real time. You see what's working and what isn't." },
  { icon: 'target',    name: 'Mobile App (iOS & Android)',     desc: "Your entire sales system in your pocket. Your team manages leads, conversations, pipeline, and follow-ups from their phone. Full desktop functionality, no desk required." },
  { icon: 'users',     name: 'Team Training & Ongoing Support',desc: "We configure everything and train your team from day one. Every team member gets a hands-on walkthrough. We stay available for customisation and support as your business grows." },
];

const tools = [
  { pay: 'CRM & pipeline management',     using: 'HubSpot, Pipedrive, Salesforce',  cost: '$50 – $400' },
  { pay: 'AI voice bot',                  using: 'Air.ai, Bland, Synthflow',        cost: '$300 – $500' },
  { pay: 'AI SMS & messaging',            using: 'Podium, Birdeye, Twilio',         cost: '$150 – $300' },
  { pay: 'Email marketing',               using: 'Mailchimp, ActiveCampaign',       cost: '$50 – $300' },
  { pay: 'Appointment scheduling',        using: 'Calendly, Acuity',                cost: '$15 – $50' },
  { pay: 'E-signatures',                  using: 'DocuSign, PandaDoc',              cost: '$25 – $50' },
  { pay: 'Review management',             using: 'Birdeye, Podium, NiceJob',        cost: '$150 – $300' },
  { pay: 'Form & landing page builder',   using: 'Typeform, Unbounce, JotForm',     cost: '$50 – $200' },
  { pay: 'Reporting & attribution',       using: 'Various',                          cost: '$50 – $200' },
  { pay: 'SMS follow-up automation',      using: 'Hatch, Drip',                      cost: '$100 – $200' },
];
const faqs = [
  { q: `What happens to my existing CRM — do I have to migrate everything?`, a: `If the existing CRM is worth keeping, the migration gets handled during the setup period. If it's not — if it's a spreadsheet, a half-used HubSpot account, or something nobody actually logs into — the new system starts clean. Lift CRM becomes the operational hub. Contact history, open deals, and active leads get imported. What doesn't come across is the noise — the dead leads and old contacts that were cluttering the pipeline anyway.` },
  { q: `Will the AI voice bot sound robotic to my customers?`, a: `No. The voice bots use natural language models — they hold real conversations, not phone trees. They're trained on your specific services, common questions, pricing structure, and the way your business talks. Most callers don't know they're talking to an AI until the bot mentions it (which it does, transparently). The goal is speed, not deception — a caller at 8pm gets a response instantly instead of a voicemail that doesn't get returned until 9am.` },
  { q: `What if a lead wants to speak to a human straight away?`, a: `The bot hands off. It's configured with escalation triggers — if the caller asks for a human, says they have an emergency, or hits a topic outside the bot's training, it offers a callback from the team or takes a message with full context attached. The human who calls back already knows what the lead asked, what they said, and where they are in the qualification process.` },
  { q: `How many follow-up messages does the system send before stopping?`, a: `The default sequence runs across 6 to 8 touches over 14 days for a new lead — Day 1, Day 3, Day 7, Day 14 — across SMS and email. After that, leads move to a long-term nurture sequence (monthly, low-frequency) rather than being marked dead. For the quote follow-up sequence, a separate track runs. All sequence lengths and frequencies get configured for the business and the sales cycle — a tradie quoting emergency jobs runs shorter sequences than a financial adviser with a 6-month consideration cycle.` },
  { q: `Do I need technical skills to manage this?`, a: `No. Everything gets configured during the setup period. The team walkthrough covers every part the team needs to use day-to-day — checking the pipeline, responding to conversations, reviewing the dashboard. The mobile app (iOS and Android) means it's accessible from a phone on the job site, not just a desk. Ongoing support is included — if something needs adjusting or a new automation needs building, that's part of the service.` },
];

---

<BaseLayout
  title="AI Sales Automation for Service Businesses | Click2Revenue"
  description="AI voice bots, SMS follow-up, CRM pipeline, and e-signatures, all connected. Every lead followed up automatically. Live in 2 weeks. AU + US service businesses."
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org", "@type": "Service",
    "name": "AI Sales Automation",
    "description": "AI voice bots, SMS follow-up, CRM pipeline, and e-signatures, all connected. Every lead followed up automatically.",
    "url": "https://click2revenue.com/services/ai-sales-automation",
    "provider": { "@type": "Organization", "name": "Click2Revenue", "url": "https://click2revenue.com" },
    "areaServed": ["AU", "US"], "serviceType": "AI Sales Automation"
  })} />
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://click2revenue.com/" },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://click2revenue.com/services" },
      { "@type": "ListItem", "position": 3, "name": "AI Sales Automation", "item": "https://click2revenue.com/services/ai-sales-automation" }
    ]
  })} />

  <!-- HERO -->
  <section style="background:#FAFAF7;padding:140px 24px 80px;position:relative;overflow:hidden;">
    <div aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;overflow:hidden;">
      <div style="position:absolute;top:-180px;right:-120px;width:900px;height:900px;background:radial-gradient(circle,rgba(153,226,180,0.22) 0%,transparent 60%);border-radius:50%;filter:blur(20px);"></div>
    </div>
    <div style="position:relative;max-width:1100px;margin:0 auto;">
      <div style="max-width:880px;margin:0 auto;text-align:center;">
        <span class="label">AI Sales Automation</span>
        <h1 style="font-size:clamp(30px,6vw,84px);font-weight:800;color:#0A0A0B;margin:0 0 24px;line-height:1.05;letter-spacing:-0.04em;text-wrap:balance;">
          Every lead followed up. Every call answered.<br class="br-desktop"/><span style="color:#14746F;">More sales. Same team.</span>
        </h1>
        <p style="font-size:clamp(17px,1.6vw,20px);color:#4A4A4E;line-height:1.55;margin:0 auto 36px;max-width:680px;font-weight:400;letter-spacing:-0.01em;">
          AI Sales Automation runs your entire sales process from the first call to the signed contract, so your team focuses on closing deals, not chasing them.
        </p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;" class="hero-cta-row">
          <a href="#full-form-anchor" class="btn-primary">Book my free audit <Icon name="arrow-right" size={16} /></a>
          <a href="#features" class="btn-secondary">See what's included</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLEM -->
  <section style="background:white;padding:110px 24px;">
    <div style="max-width:1100px;margin:0 auto;">
      <div class="reveal" style="max-width:760px;margin-bottom:56px;text-align:center;margin-inline:auto;">
        <h2 style="font-size:clamp(32px,4.5vw,54px);color:#0A0A0B;margin:0;line-height:1.05;letter-spacing:-0.035em;">
          Your sales process is <span style="color:#14746F;">leaking revenue</span> at every stage.
        </h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;" class="pain-grid">
        {pains.map(p => (
          <div class="reveal" style="padding:36px 32px;background:#FAFAF7;border:1px solid #EAEAEC;border-radius:16px;">
            <h3 style="font-weight:700;font-size:19px;color:#14746F;margin:0 0 14px;letter-spacing:-0.02em;line-height:1.3;">{p.title}</h3>
            <p style="font-size:14.5px;color:#4A4A4E;line-height:1.7;margin:0;letter-spacing:-0.005em;">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section style="background:#F6F5F0;padding:110px 24px;">
    <div style="max-width:1100px;margin:0 auto;">
      <div class="reveal" style="text-align:center;max-width:700px;margin:0 auto 64px;">
        <span class="label">How it works</span>
        <h2 style="font-size:clamp(30px,4.5vw,50px);color:#0A0A0B;margin:0;line-height:1.05;letter-spacing:-0.035em;">
          Here's what happens <span style="color:#14746F;">from day one.</span>
        </h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;" class="steps-grid">
        {steps.map(s => (
          <div class="reveal" style="padding:40px 32px;background:white;border:1px solid #EAEAEC;border-radius:16px;">
            <p style="font-weight:700;font-size:14px;color:#14746F;margin:0 0 22px;letter-spacing:0.05em;">{s.n}</p>
            <h3 style="font-weight:700;font-size:19px;margin:0 0 14px;color:#0A0A0B;letter-spacing:-0.02em;line-height:1.25;">{s.t}</h3>
            <p style="font-size:14.5px;color:#4A4A4E;line-height:1.65;margin:0;letter-spacing:-0.005em;">{s.b}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features" style="background:white;padding:110px 24px;">
    <div style="max-width:1240px;margin:0 auto;">
      <div class="reveal" style="text-align:center;max-width:700px;margin:0 auto 56px;">
        <span class="label">What's included</span>
        <h2 style="font-size:clamp(30px,4.5vw,50px);color:#0A0A0B;margin:0;line-height:1.05;letter-spacing:-0.035em;">
          Everything your sales process<br class="br-desktop"/> needs. <span style="color:#14746F;">One platform.</span>
        </h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;" class="feat-grid-4">
        {features.map(f => (
          <div class="reveal" style="padding:26px 22px;background:#FAFAF7;border:1px solid #EAEAEC;border-radius:14px;">
            <div style="display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:9px;background:white;border:1px solid #EAEAEC;color:#14746F;margin-bottom:14px;">
              <Icon name={f.icon} size={18} />
            </div>
            <h3 style="font-weight:700;font-size:15px;margin:0 0 8px;color:#0A0A0B;letter-spacing:-0.02em;line-height:1.3;">{f.name}</h3>
            <p style="font-size:13px;color:#4A4A4E;line-height:1.6;margin:0;letter-spacing:-0.005em;">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TOOLS YOU CAN CANCEL -->
  <section style="background:#F6F5F0;padding:110px 24px;">
    <div style="max-width:1100px;margin:0 auto;">
      <div class="reveal" style="text-align:center;max-width:780px;margin:0 auto 56px;">
        <span class="label">Tools you can cancel</span>
        <h2 style="font-size:clamp(30px,4.5vw,50px);color:#0A0A0B;margin:0 0 18px;line-height:1.05;letter-spacing:-0.035em;">
          One system replaces <span style="color:#14746F;">all of these.</span>
        </h2>
        <p style="font-size:16px;color:#4A4A4E;line-height:1.6;margin:0;letter-spacing:-0.005em;">
          Most businesses running on separate tools spend $1,200 to $2,000+ per month on software that doesn't connect. Here's what the Click2Revenue Platform replaces.
        </p>
      </div>

      <div class="reveal" style="background:white;border:1px solid #EAEAEC;border-radius:18px;overflow:hidden;">
        <div class="tool-head" style="display:grid;grid-template-columns:1.4fr 1.4fr 1fr;gap:0;padding:18px 28px;background:#FAFAF7;border-bottom:1px solid #EAEAEC;font-family:'Inter',sans-serif;font-weight:600;font-size:11.5px;letter-spacing:0.1em;text-transform:uppercase;color:#8A8A90;">
          <span>What you're paying for</span>
          <span>Tools you're probably using</span>
          <span style="text-align:right;">Typical monthly cost</span>
        </div>
        {tools.map(t => (
          <div class="tool-row" style="display:grid;grid-template-columns:1.4fr 1.4fr 1fr;gap:0;padding:16px 28px;border-bottom:1px solid #EAEAEC;align-items:center;">
            <span style="font-size:14.5px;color:#0A0A0B;font-weight:500;letter-spacing:-0.005em;">{t.pay}</span>
            <span style="font-size:13.5px;color:#8A8A90;letter-spacing:-0.005em;">{t.using}</span>
            <span style="font-size:14.5px;color:#14746F;font-weight:700;text-align:right;letter-spacing:-0.01em;">{t.cost}</span>
          </div>
        ))}
      </div>

      <div class="reveal" style="margin-top:24px;padding:28px 36px;background:#0A0A0B;border-radius:14px;text-align:center;">
        <p style="margin:0;font-size:17px;color:white;line-height:1.55;font-weight:500;letter-spacing:-0.01em;">
          Most clients cut their software bill by <span style="color:#99E2B4;font-weight:700;">50% or more</span> in the first 90 days. And end up with a platform that actually connects.
        </p>
      </div>
      <p style="margin:16px 0 0;font-size:12px;color:#8A8A90;text-align:center;font-style:italic;">
        Costs are indicative ranges based on standard published pricing. Actual savings depend on your current stack.
      </p>
    </div>
  </section>


  <!-- ═══ FAQ ═══ -->
  <FAQSection
    kicker="Frequently asked"
    heading="AI Sales Automation"
    accent="questions answered"
    faqs={faqs}
    background="white"
  />

  <UniversalBottom
    service="ai_sales_automation"
    source="service_page"
    guaranteeText="If your AI Sales Automation system isn't live and responding to leads 14 days after kickoff, your first month is on us. No small print."
    formHeadline="Ready to let AI handle your sales follow-up?"
    formSubheadline="A free audit of your current sales process runs within 24 hours. Our AI replies instantly. A human follows up during business hours."
  />

</BaseLayout>

<style>
  @media (max-width: 1000px) {
    .pain-grid    { grid-template-columns: 1fr !important; }
    .steps-grid   { grid-template-columns: 1fr !important; }
    .feat-grid-4  { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (max-width: 760px) {
    section:first-child { padding: 120px 18px 64px !important; }
    section { padding-left: 18px !important; padding-right: 18px !important; padding-top: 64px !important; padding-bottom: 64px !important; }
    .feat-grid-4 { grid-template-columns: 1fr !important; }
    .hero-cta-row a { width: 100%; justify-content: center; }
    .tool-head, .tool-row { grid-template-columns: 1fr !important; gap: 4px !important; padding: 14px 20px !important; }
    .tool-head span:nth-child(3), .tool-row span:nth-child(3) { text-align: left !important; }
    .tool-head { display: none !important; }
  }
</style>
